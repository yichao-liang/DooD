[MASTER]

extension-pkg-whitelist=numpy,torch,kornia,pybullet
ignore=CVS,venv,.venv,build,dist

[MESSAGES CONTROL]

# Disabled checks:
# - Style/taste that black/isort already govern, or that research code
#   routinely violates without being a bug.
# - Complexity metrics (too-many-*): research modules trip them by design.
# - Import/name rules: research modules use wildcard imports for brevity
#   and commonly shadow outer names with argparse.Namespace fields.
# - Pylint's ability to follow torch/kornia dynamic attribute access is
#   limited, so `no-member`, `unexpected-keyword-arg`, etc. produce more
#   false positives than signal here.
# - Cyclic imports exist between dood.util and dood.models.*; a genuine
#   refactor target but not a runtime bug.
disable=
    # Documentation style
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    # Line length (black wraps code; this fires on long f-strings/comments)
    line-too-long,
    # Names and scoping (research code style)
    invalid-name,
    redefined-outer-name,
    redefined-builtin,
    redefined-argument-from-local,
    ungrouped-imports,
    wrong-import-order,
    wrong-import-position,
    wildcard-import,
    unused-wildcard-import,
    consider-using-from-import,
    import-outside-toplevel,
    cyclic-import,
    # Unused / dead identifiers (very common in research)
    unused-import,
    unused-variable,
    unused-argument,
    pointless-string-statement,
    pointless-statement,
    expression-not-assigned,
    # Complexity metrics
    too-many-lines,
    too-many-locals,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-branches,
    too-many-statements,
    too-many-instance-attributes,
    too-many-public-methods,
    too-many-return-statements,
    too-many-nested-blocks,
    too-many-boolean-expressions,
    too-few-public-methods,
    # Style
    no-else-return,
    no-else-raise,
    no-else-continue,
    no-else-break,
    consider-using-f-string,
    consider-using-in,
    consider-using-enumerate,
    consider-using-with,
    consider-using-generator,
    f-string-without-interpolation,
    trailing-whitespace,
    trailing-newlines,
    singleton-comparison,
    unidiomatic-typecheck,
    unnecessary-comprehension,
    unnecessary-lambda,
    unnecessary-lambda-assignment,
    unnecessary-pass,
    superfluous-parens,
    using-constant-test,
    duplicate-code,
    # Defensive programming idioms common in research code
    dangerous-default-value,
    broad-exception-caught,
    broad-exception-raised,
    bare-except,
    raise-missing-from,
    logging-format-interpolation,
    logging-fstring-interpolation,
    logging-not-lazy,
    fixme,
    global-statement,
    # PyTorch/kornia/matplotlib dynamic attributes mislead pylint
    no-member,
    not-callable,
    unsubscriptable-object,
    # Common ML idioms
    abstract-method,
    super-init-not-called,
    attribute-defined-outside-init,
    protected-access,
    arguments-differ,
    arguments-renamed,
    method-hidden,
    signature-differs,
    # Breakpoints used as defensive guards inside if-nan branches
    forgotten-debug-statement,
    # Deferred bug-catch: these often fire on research code (dynamic
    # control flow via argparse flags) but may hide real issues; enable
    # per-module once the module is cleaned.
    possibly-used-before-assignment,
    used-before-assignment,
    undefined-variable,
    undefined-loop-variable,
    unreachable,
    unexpected-keyword-arg,
    no-value-for-parameter,
    # Mypy catches real call errors; pylint's inference on torch/einops is noisy
    not-an-iterable,
    not-a-mapping,
    unsupported-assignment-operation,
    unsupported-membership-test,
    unbalanced-tuple-unpacking

[REPORTS]

evaluation=10.0 - ((float(5 * error + warning + refactor + convention) / statement) * 10)
output-format=text

[BASIC]

good-names=i,j,k,n,m,x,y,z,t,s,e,c,h,w,_

[FORMAT]

max-line-length=88
indent-string='    '

[VARIABLES]

init-import=no
dummy-variables-rgx=_$|dummy|^ignored_|^unused_
